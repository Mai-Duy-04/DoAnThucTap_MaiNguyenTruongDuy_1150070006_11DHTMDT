@model TourWebApp.Data.Models.DonDatTour
@{
    var tongGoc = Model.TongTien;
    var soTienGiam = Model.SoTienGiam ?? 0;
    var tongThanhToan = Model.TongTienSauGiam ?? (tongGoc - soTienGiam);
    if (tongThanhToan < 0) { tongThanhToan = 0; }
    var checkInToken = ViewBag.CheckInToken as string;
    var checkinUrl = !string.IsNullOrWhiteSpace(checkInToken)
        ? Url.Action("ScanCheckIn", "QuanLyDon", new { token = checkInToken }, Context.Request.Scheme)
        : null;
    var checkinQrUrl = !string.IsNullOrWhiteSpace(checkinUrl)
        ? $"https://api.qrserver.com/v1/create-qr-code/?size=240x240&data={Uri.EscapeDataString(checkinUrl)}"
        : null;
}

<style>
    .done-wrap { max-width: 1460px; margin: 20px auto; padding: 0 16px; }
    .ticket-done {
        display: grid;
        grid-template-columns: 1.28fr 0.72fr;
        background: #fff;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 18px 40px rgba(17, 24, 39, .12);
        min-height: 620px;
    }
    .ticket-main { padding: 28px 32px; background: linear-gradient(180deg,#ffffff 0%,#f8fbff 100%); }
    .ticket-side { padding: 28px 24px; background: #0f172a; color: #e2e8f0; position: relative; }
    .ticket-side:before, .ticket-side:after { content: ""; position: absolute; left: -16px; width: 32px; height: 32px; border-radius: 50%; background: #f3f4f6; }
    .ticket-side:before { top: 140px; }
    .ticket-side:after { bottom: 140px; }
    .ticket-dash { border-top: 2px dashed rgba(148,163,184,.45); margin: 14px 0 16px; }
    .ticket-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px 22px; }
    .ticket-row { margin-bottom: 8px; }
    .ticket-row .k { color: #64748b; font-size: .92rem; }
    .ticket-row .v { font-weight: 700; color: #0f172a; }
    .pay-total { font-size: 1.5rem; font-weight: 800; color: #dc2626; }
    @@media (max-width: 992px) {
        .ticket-done { grid-template-columns: 1fr; min-height: auto; }
        .ticket-side:before, .ticket-side:after { display: none; }
    }
</style>

<div class="done-wrap">
    <div class="ticket-done">
        <section class="ticket-main">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <h2 class="text-success fw-bold mb-1"><i class="fa-solid fa-circle-check"></i> THANH TOÁN THÀNH CÔNG</h2>
                    <p class="text-muted mb-0">Cảm ơn bạn đã tin tưởng HappyTrip</p>
                </div>
                <div class="booking-box p-2 px-3 rounded-3" style="background:#F1F8FF; border:1px solid #B6D9FF;">
                    <strong>Mã Booking:</strong> <span class="text-primary fw-bold">@Model.MaBooking</span>
                </div>
            </div>

            <div class="ticket-dash"></div>
            <h5 class="fw-bold mb-3 text-primary">Thông tin đơn hàng</h5>
            <div class="ticket-grid">
                <div class="ticket-row"><div class="k">Tên tour</div><div class="v">@Model.IdTourNavigation.TenTour</div></div>
                <div class="ticket-row"><div class="k">Ngày khởi hành</div><div class="v">@Model.IdLichNavigation.NgayKhoiHanh.ToString("dd/MM/yyyy")</div></div>
                <div class="ticket-row"><div class="k">Số lượng khách</div><div class="v">@Model.NguoiLon NL, @Model.TreEm TE, @Model.TreNho EB</div></div>
                <div class="ticket-row"><div class="k">Thanh toán lúc</div><div class="v">@Model.NgayThanhToan?.ToString("HH:mm dd/MM/yyyy")</div></div>
                <div class="ticket-row"><div class="k">Tổng tiền gốc</div><div class="v">@tongGoc.ToString("N0") đ</div></div>
                <div class="ticket-row"><div class="k">Giảm giá</div><div class="v">-@soTienGiam.ToString("N0") đ</div></div>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.MaPhieuGiamGia))
            {
                <div class="mt-2"><span class="badge bg-success">Voucher: @Model.MaPhieuGiamGia</span></div>
            }
            <div class="mt-3">Tổng thanh toán: <span class="pay-total">@tongThanhToan.ToString("N0") đ</span></div>
            <div class="text-center mt-4">
            <p class="text-muted mb-1">Thông tin xác nhận đã được gửi qua Email/SĐT của bạn.</p>
            <p class="mb-2">Cần hỗ trợ? Gọi ngay <strong>0938 179 170</strong></p>
            <a href="/" class="btn btn-primary rounded-pill px-5 py-2 fw-bold mt-2">Về trang chủ</a>
            </div>
        </section>

        <aside class="ticket-side d-flex flex-column align-items-center justify-content-center">
            <h5 class="fw-bold mb-2 text-white">THE CHECK-IN</h5>
            <p class="mb-3 text-center" style="color:#94a3b8;">Xuất trình mã này tại điểm tập trung</p>
            @if (!string.IsNullOrWhiteSpace(checkinQrUrl))
            {
                <img src="@checkinQrUrl" alt="QR check-in @Model.MaBooking" style="width:220px;height:220px;border:8px solid #fff;border-radius:16px;background:#fff;" />
            }
            <div class="mt-3 px-3 py-2 rounded-3" style="background:#111827; border:1px solid #334155;">
                <span style="color:#cbd5e1;">Booking:</span> <strong class="text-white">@Model.MaBooking</strong>
            </div>
        </aside>
    </div>
</div>
