@model List<TourWebApp.Data.Models.DonDatTour>
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<h3 class="fw-bold mb-4">Quản lý đơn đặt tour</h3>

@{
    var pendingCashCount = ViewBag.PendingCashCount as int? ?? 0;
}

@if (pendingCashCount > 0)
{
    <div class="alert alert-info d-flex justify-content-between align-items-center" role="alert">
        <div><strong>@pendingCashCount</strong> đơn đang chờ admin xác nhận thủ công.</div>
        <a class="btn btn-sm btn-primary" href="@Url.Action("Index", "QuanLyDon", new { trangThai = "ChoXacNhanTienMat" })">Xem ngay</a>
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-warning">@TempData["Error"]</div>
}

<form method="get" class="mb-3 card card-body">
    <div class="row g-2">
        <div class="col-12 col-md-3">
            <label class="form-label mb-1">Trạng thái</label>
            <select name="trangThai" class="form-select">
                <option value="TatCa">Tất cả</option>
                <option value="ChoDuyet" selected="@(ViewBag.TrangThai=="ChoDuyet")">Chờ duyệt</option>
                <option value="DaDuyet" selected="@(ViewBag.TrangThai=="DaDuyet")">Đã duyệt</option>
                <option value="DaHuy" selected="@(ViewBag.TrangThai=="DaHuy")">Đã hủy</option>
                <option value="DaThanhToan" selected="@(ViewBag.TrangThai=="DaThanhToan")">Đã thanh toán</option>
                <option value="ChuaThanhToan" selected="@(ViewBag.TrangThai=="ChuaThanhToan")">Chưa thanh toán</option>
                <option value="ChoXacNhanTienMat" selected="@(ViewBag.TrangThai=="ChoXacNhanTienMat")">Chờ xác nhận thủ công</option>
            </select>
        </div>

        <div class="col-6 col-md-2">
            <label class="form-label mb-1">Ngày đặt từ</label>
            <input type="date" name="ngayDatTu" class="form-control" value="@ViewBag.NgayDatTu" />
        </div>

        <div class="col-6 col-md-2">
            <label class="form-label mb-1">Đến ngày</label>
            <input type="date" name="ngayDatDen" class="form-control" value="@ViewBag.NgayDatDen" />
        </div>

        <div class="col-12 col-md-2">
            <label class="form-label mb-1">Phương thức TT</label>
            <select name="phuongThucTT" class="form-select">
                <option value="TatCa" selected="@(ViewBag.PhuongThucTT=="TatCa")">Tất cả</option>
                <option value="VNPAY" selected="@(ViewBag.PhuongThucTT=="VNPAY")">VNPAY</option>
                <option value="ChuyenKhoanQR" selected="@(ViewBag.PhuongThucTT=="ChuyenKhoanQR")">Chuyển khoản QR</option>
                <option value="TienMat" selected="@(ViewBag.PhuongThucTT=="TienMat")">Tiền mặt</option>
                <option value="MienPhi" selected="@(ViewBag.PhuongThucTT=="MienPhi")">Miễn phí</option>
            </select>
        </div>

        <div class="col-12 col-md-3">
            <label class="form-label mb-1">Mã đơn / Tên khách</label>
            <input type="text"
                   name="tuKhoa"
                   class="form-control"
                   value="@ViewBag.TuKhoa"
                   placeholder="Nhập mã booking hoặc tên khách" />
        </div>
    </div>

    <div class="d-flex gap-2 mt-3">
        <button class="btn btn-primary" type="submit">Lọc</button>
        <button class="btn btn-success"
                type="submit"
                formaction="@Url.Action("ExportExcel", "QuanLyDon")">
            Xuất Excel
        </button>
        <a class="btn btn-outline-secondary" href="@Url.Action("Index", "QuanLyDon")">Đặt lại</a>
    </div>
</form>

<table class="table table-bordered align-middle">
    <thead class="table-dark">
        <tr>
            <th>Mã booking</th>
            <th>Khách hàng</th>
            <th>Tour</th>
            <th>Ngày đặt</th>
            <th>Tổng gốc</th>
            <th>Tổng TT</th>
            <th>Trạng thái</th>
            <th width="160">Thao tác</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var d in Model)
        {
            var tongThanhToan = d.TongTienSauGiam ?? (d.TongTien - (d.SoTienGiam ?? 0));
            if (tongThanhToan < 0) { tongThanhToan = 0; }

            <tr>
                <td>@d.MaBooking</td>
                <td>@d.IdTaiKhoanNavigation.HoTen</td>
                <td>@d.IdTourNavigation.TenTour</td>
                <td>@d.NgayDat.ToString("dd/MM/yyyy")</td>
                <td>@String.Format("{0:#,0}đ", d.TongTien)</td>
                <td>
                    @String.Format("{0:#,0}đ", tongThanhToan)
                    @if (!string.IsNullOrWhiteSpace(d.MaPhieuGiamGia))
                    {
                        <div class="small text-success">@d.MaPhieuGiamGia</div>
                    }
                </td>
                <td>
                    @if (d.DaThanhToan)
                    {
                        <span class="badge bg-success">Đã thanh toán</span>
                    }
                    else if (d.TrangThai == "DaHuy")
                    {
                        <span class="badge bg-danger">Đã hủy</span>
                    }
                    else if (d.TrangThai == "ChoXacNhanTienMat")
                    {
                        <span class="badge bg-info text-dark">Chờ xác nhận thủ công</span>
                    }
                    else if (d.HanThanhToan != null && d.HanThanhToan < DateTime.Now)
                    {
                        <span class="badge bg-secondary">Hết hạn thanh toán</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Chờ thanh toán</span>
                    }
                </td>

                <td>
                    <a asp-action="ChiTiet" asp-route-id="@d.IdDon" class="btn btn-primary btn-sm">Xem</a>

                    @if (!d.DaThanhToan)
                    {
                        <form asp-action="Xoa"
                              method="post"
                              class="d-inline"
                              onsubmit="return confirm('Xóa đơn chưa thanh toán này?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@d.IdDon" />
                            <button class="btn btn-danger btn-sm">Xóa</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
