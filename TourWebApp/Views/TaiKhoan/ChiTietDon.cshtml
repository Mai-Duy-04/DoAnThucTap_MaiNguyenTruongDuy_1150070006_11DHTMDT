@model TourWebApp.Data.Models.DonDatTour
@{
    ViewData["Title"] = "Chi tiết đơn tour";
    Layout = "_Layout";

    var tongKhach = (Model?.NguoiLon ?? 0) + (Model?.TreEm ?? 0) + (Model?.TreNho ?? 0);
    var nguoiLon = Model?.NguoiLon ?? 0;
    var treEm = Model?.TreEm ?? 0;
    var treNho = Model?.TreNho ?? 0;
    var tongGoc = Model?.TongTien ?? 0;
    var soTienGiam = Model?.SoTienGiam ?? 0;
    var tongSauGiam = Model?.TongTienSauGiam ?? (tongGoc - soTienGiam);
    if (tongSauGiam < 0) { tongSauGiam = 0; }

    var tenTour = Model?.IdTourNavigation?.TenTour ?? "Tour đang cập nhật";
    var ngayKhoiHanh = Model?.IdLichNavigation?.NgayKhoiHanh;
    var gioKhoiHanh = Model?.IdLichNavigation?.GioKhoiHanh;
    var gioKhoiHanhText = gioKhoiHanh.HasValue ? gioKhoiHanh.Value.ToString("HH:mm") : "Đang cập nhật";
    var diaDiemKhoiHanh = Model?.IdTourNavigation?.DiaDiem ?? "Đang cập nhật";
    var maPhieu = Model?.MaPhieuGiamGia;

    var trangThai = Model?.TrangThai ?? "KhôngXácĐịnh";
    var statusClass = "st-wait";
    if (trangThai == "ThanhToanThanhCong" || trangThai == "HoanTat") { statusClass = "st-success"; }
    else if (trangThai == "DaHuy" || trangThai == "HetHanThanhToan") { statusClass = "st-cancel"; }

    var tour = Model?.IdTourNavigation;
    var anhTour = tour?.HinhAnh;
    var tenNguoiDat = Model?.IdTaiKhoanNavigation?.HoTen;
    var sdtNguoiDat = Model?.IdTaiKhoanNavigation?.SoDienThoai;
    var emailNguoiDat = Model?.IdTaiKhoanNavigation?.Email;
    var maBooking = Model?.MaBooking ?? "---";
    var ghiChu = Model?.GhiChu ?? string.Empty;
    var idTour = Model?.IdTour ?? 0;
    var idLich = Model?.IdLich ?? 0;
    var trangThaiThanhToan = Model?.TrangThaiThanhToan;
    var phuongThucThanhToan = Model?.PhuongThucTT;
    var daThanhToanThanhCong = trangThai == "ThanhToanThanhCong" || trangThai == "HoanTat" || Model?.DaThanhToan == true;
    var checkInToken = ViewBag.CheckInToken as string;
    var checkinUrl = !string.IsNullOrWhiteSpace(checkInToken)
        ? Url.Action("ScanCheckIn", "QuanLyDon", new { token = checkInToken }, Context.Request.Scheme)
        : null;
    var checkinQrUrl = !string.IsNullOrWhiteSpace(checkinUrl)
        ? $"https://api.qrserver.com/v1/create-qr-code/?size=240x240&data={Uri.EscapeDataString(checkinUrl)}"
        : null;

    var timelineStep2 = Model?.DaThanhToan == true ? "done" : "wait";
    var timelineStep3 = (trangThai == "DaHuy") ? "cancel" : (Model?.DaThanhToan == true ? "done" : "wait");
    var ngayDatText = Model?.NgayDat.ToString("dd/MM/yyyy HH:mm") ?? "Chưa cập nhật";
    var ngayDatNganText = Model?.NgayDat.ToString("dd/MM HH:mm") ?? "--/-- --:--";
}

<link rel="stylesheet" href="~/css/booking-ticket.css" asp-append-version="true" />

<div class="ticket-page">
    <div class="booking-ticket">
        <div class="ticket-header">
            <div>
                <p class="ticket-kicker">Travel e-ticket</p>
                <h2>Phiếu xác nhận đặt tour</h2>
                <p>Theo dõi toàn bộ trạng thái đơn hàng của bạn tại HappyTrip.</p>
            </div>
            <div class="ticket-head-meta">
                <p class="ticket-booking-code">Mã đơn: <strong>@maBooking</strong></p>
                <p class="ticket-created-time">Ngày đặt: @ngayDatText</p>
                <span class="ticket-status @statusClass">@trangThai</span>
            </div>
        </div>

        <div class="ticket-progress-horizontal" aria-label="Booking progress">
            <div class="hp-step done">
                <span class="dot"></span>
                <strong>Tạo đơn</strong>
                <small>@ngayDatNganText</small>
            </div>
            <div class="hp-step @(timelineStep2 == "done" ? "done" : "wait")">
                <span class="dot"></span>
                <strong>Thanh toán</strong>
                <small>@(Model?.NgayThanhToan?.ToString("dd/MM HH:mm") ?? "Chưa TT")</small>
            </div>
            <div class="hp-step @(timelineStep3 == "cancel" ? "cancel" : (timelineStep3 == "done" ? "done" : "wait"))">
                <span class="dot"></span>
                <strong>@(trangThai == "DaHuy" ? "Đã hủy" : "Xác nhận")</strong>
                <small>@(Model?.NgayHuy?.ToString("dd/MM HH:mm") ?? "Đang xử lý")</small>
            </div>
            <div class="hp-step @((trangThai == "HoanTat" || trangThai == "ThanhToanThanhCong") ? "done" : "wait")">
                <span class="dot"></span>
                <strong>Hoàn tất</strong>
                <small>@((trangThai == "HoanTat" || trangThai == "ThanhToanThanhCong") ? "Sẵn sàng" : "Đang chờ")</small>
            </div>
        </div>

        <div class="ticket-main">
            <div class="ticket-pane-left">
                <section class="ticket-section">
                    <p class="ticket-section-tag">Booking ticket</p>
                    <div class="ticket-tour-head">
                        @if (!string.IsNullOrWhiteSpace(anhTour))
                        {
                            <img src="@anhTour" alt="@tenTour" class="ticket-tour-thumb" />
                        }
                        <div>
                            <h3>@tenTour</h3>
                            <p class="ticket-tour-sub">Hành trình đã được giữ chỗ thành công.</p>
                        </div>
                    </div>
                    <div class="ticket-kv">
                        <p><span>Ngày khởi hành</span><strong>@(ngayKhoiHanh?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")</strong></p>
                        <p><span>Giờ khởi hành</span><strong>@gioKhoiHanhText</strong></p>
                        <p><span>Điểm khởi hành</span><strong>@diaDiemKhoiHanh</strong></p>
                        @if (!string.IsNullOrWhiteSpace(tour?.MaTour)) { <p><span>Mã tour</span><strong>@tour.MaTour</strong></p> }
                        @if (!string.IsNullOrWhiteSpace(tour?.PhuongTien)) { <p><span>Phương tiện</span><strong>@tour.PhuongTien</strong></p> }
                        @if (!string.IsNullOrWhiteSpace(tour?.ThoiGian)) { <p><span>Thời lượng</span><strong>@tour.ThoiGian</strong></p> }
                        @if (!string.IsNullOrWhiteSpace(maPhieu)) { <p><span>Mã phiếu</span><strong>@maPhieu</strong></p> }
                    </div>
                </section>

                <section class="ticket-section">
                    <p class="ticket-section-tag">Passenger info</p>
                    <h4>Hành khách & số lượng</h4>
                        <p><span>Tổng khách</span><strong>@tongKhach người</strong></p>
                        <p><span>Người lớn</span><strong>@nguoiLon</strong></p>
                        <p><span>Trẻ em</span><strong>@treEm</strong></p>
                        <p><span>Em bé</span><strong>@treNho</strong></p>
                        @if (!string.IsNullOrWhiteSpace(tenNguoiDat)) { <p><span>Người đặt</span><strong>@tenNguoiDat</strong></p> }
                        @if (!string.IsNullOrWhiteSpace(sdtNguoiDat)) { <p><span>Số điện thoại</span><strong>@sdtNguoiDat</strong></p> }
                        @if (!string.IsNullOrWhiteSpace(ghiChu)) { <p><span>Ghi chú</span><strong>@ghiChu</strong></p> }
                        @if (!string.IsNullOrWhiteSpace(emailNguoiDat)) { <p><span>Email</span><strong>@emailNguoiDat</strong></p> }
                        @if (!string.IsNullOrWhiteSpace(ghiChu)) { <p><span>Ghi chu</span><strong>@ghiChu</strong></p> }
                    </div>
                </section>
            </div>

            <aside class="ticket-pane-right">
                <section class="ticket-section ticket-summary">
                    <p class="ticket-section-tag">Payment summary</p>
                    <h4>Tổng thanh toán</h4>
                    <p class="ticket-total-amount">@tongSauGiam.ToString("N0") đ</p>
                    <div class="ticket-kv">
                        <p><span>Tổng gốc</span><strong>@tongGoc.ToString("N0") đ</strong></p>
                        <p><span>Giảm giá</span><strong>-@soTienGiam.ToString("N0") đ</strong></p>
                        @if (!string.IsNullOrWhiteSpace(maPhieu)) { <p><span>Mã phiếu</span><strong>@maPhieu</strong></p> }
                        <p><span>Mã đơn</span><strong>@maBooking</strong></p>
                        <p><span>Ngày đặt</span><strong>@ngayDatText</strong></p>
                        <p><span>Trạng thái TT</span><strong>@(string.IsNullOrWhiteSpace(trangThaiThanhToan) ? "Chưa có" : trangThaiThanhToan)</strong></p>
                        <p><span>PT thanh toán</span><strong>@(string.IsNullOrWhiteSpace(phuongThucThanhToan) ? "Chưa cập nhật" : phuongThucThanhToan)</strong></p>
                    </div>
                    @if (daThanhToanThanhCong && !string.IsNullOrWhiteSpace(checkinQrUrl))
                    {
                        <div class="ticket-qr">
                            <img src="@checkinQrUrl" alt="QR check-in @maBooking" class="ticket-qr-box" />
                            <p>QR CHECK-IN</p>
                            <strong>@maBooking</strong>
                        </div>
                    }
                </section>

                <section class="ticket-section">
                    <p class="ticket-section-tag">Actions</p>
                    <div class="ticket-actions">
                        @if (trangThai == "ChoThanhToan" || trangThai == "ChoXacNhanTienMat")
                        {
                            <form asp-action="HuyDonTuKhach" asp-controller="DatTour" method="post" class="w-100 mb-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="idDon" value="@Model.IdDon" />
                                <textarea name="lyDoHuy" class="form-control mb-2" rows="2" placeholder="Lý do hủy đơn (không bắt buộc)"></textarea>
                                <button type="submit" class="ticket-btn ticket-btn-sand w-100" onclick="return confirm('Bạn chắc chắn muốn hủy đơn này?');">Hủy đơn</button>
                            </form>
                        }
                        @if (trangThai == "DaHuy" || trangThai == "HetHanThanhToan")
                        {
                            <a class="ticket-btn ticket-btn-sand" href="/DatTour/NhapThongTin?idTour=@idTour&idLich=@idLich&adult=@nguoiLon&child=@treEm&baby=@treNho">
                                Đặt lại đơn mới
                            </a>
                        }
                        <a class="ticket-btn ticket-btn-primary" href="/TaiKhoan/DonCuaToi">Quay lại danh sách đơn</a>
                        <a class="ticket-btn ticket-btn-outline" href="mailto:happytrip@gmail.com">Liên hệ hỗ trợ</a>
                    </div>
                </section>

                <section class="ticket-support-strip">
                    <h5>Lưu ý khi tham gia tour</h5>
                    <ul>
                        <li>Có mặt trước giờ khởi hành 30 phút.</li>
                        <li>Mang theo CCCD/giấy tờ tùy thân.</li>
                    </ul>
                    <p><strong>Email:</strong> happytrip@gmail.com</p>
                    <p><strong>Hotline:</strong> +84 938 179 170</p>
                </section>
            </aside>
        </div>
    </div>
</div>
