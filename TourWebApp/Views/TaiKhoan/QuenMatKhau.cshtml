@{
    ViewData["Title"] = "Quên mật khẩu";
}

<link rel="stylesheet" href="~/css/auth.css" />

<div class="auth-bg">
    <div class="auth-container">
        <div class="auth-box">
            <h2>Quên mật khẩu</h2>
            <p>Nhập email và mật khẩu mới để khôi phục tài khoản</p>

            @if (ViewBag.ThongBao != null)
            {
                <div class="error-text">@ViewBag.ThongBao</div>
            }

            <form method="post" asp-controller="TaiKhoan" asp-action="QuenMatKhau">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <input type="email" name="Email" placeholder="Email tài khoản" required />
                </div>

                <div class="form-group password-wrapper">
                    <input type="password" id="MatKhauMoi" name="MatKhauMoi" placeholder="Mật khẩu mới" required />
                    <span class="toggle-password" onclick="togglePassword('MatKhauMoi', this)">
                        <i class="fas fa-eye"></i>
                    </span>
                </div>

                <div class="form-group password-wrapper">
                    <input type="password" id="NhapLaiMatKhauMoi" name="NhapLaiMatKhauMoi" placeholder="Nhập lại mật khẩu mới" required />
                    <span class="toggle-password" onclick="togglePassword('NhapLaiMatKhauMoi', this)">
                        <i class="fas fa-eye"></i>
                    </span>
                </div>

                <button type="submit" class="btn-login">CẬP NHẬT MẬT KHẨU</button>

                <div class="register-link">
                    <a asp-controller="TaiKhoan" asp-action="DangNhap">Quay lại đăng nhập</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="~/js/password-validation.js"></script>
